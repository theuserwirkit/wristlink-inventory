# Konfigurator – zusätzliche Umgebungsvariablen
# In .env.local bzw. Vercel eintragen

# Öffentliche App-URL (für E-Mail-Links, Stripe, Telegram)
NEXT_PUBLIC_APP_URL=https://braceled-led-armband.com

# n8n → Wristlink API (gleiche Domain wie Production)
WRISTLINK_API_URL=https://braceled-led-armband.com

# Admin-Login-Passwort (nur in .env.local / Vercel – nicht in next.config.mjs env-Block)
WRISTLINK_PASSWORD=

# Admin-Session-Secret (HMAC-SHA256 Signatur des Session-Cookies).
# WICHTIG: bewusst NICHT identisch mit WRISTLINK_PASSWORD wählen –
# so bleiben Login-Passwort und Session-Signatur getrennt. Ein langer,
# zufälliger Wert, z. B. `openssl rand -hex 32`.
# Fallback: Ist die Variable nicht gesetzt, wird zur Migration weiterhin
# WRISTLINK_PASSWORD als Session-Secret verwendet.
WRISTLINK_SESSION_SECRET=

# Lead-Session (optional, sonst WRISTLINK_PASSWORD)
LEAD_SESSION_SECRET=

# Resend (Double Opt-In + Transaktionsmails)
RESEND_API_KEY=
RESEND_FROM_EMAIL="BraceLED <angebote@braceled-led-armband.com>"
TEAM_NOTIFICATION_EMAIL=angebote@braceled-led-armband.com

# Telegram (Benachrichtigung + Freigabe-Buttons)
# WICHTIG: TELEGRAM_WEBHOOK_SECRET ist Pflicht – ohne dieses Secret
# antwortet der Webhook-Endpoint mit 401 (fail-closed).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Konfigurator-Testmode (DOI-Bypass)
# In Nicht-Production immer aktiv. In Production standardmäßig blockiert (403).
# Zum Aktivieren in Production BEIDE Werte setzen und den geheimen Wert
# als Header `x-testmode-secret` mitsenden.
KONFIGURATOR_TESTMODE_ENABLED=false
KONFIGURATOR_TESTMODE_SECRET=

# Stripe (Testmodus zuerst; Rechnung via invoice_creation)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Rate-Limiting (optional – Upstash Redis / Vercel KV; sonst In-Memory pro Instanz)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Webhook-URLs (nach Deploy eintragen):
# Stripe: https://braceled-led-armband.com/api/stripe/webhook
# Telegram: https://braceled-led-armband.com/api/telegram/webhook

# sevDesk (Angebote/Rechnungen – optional, sonst manueller PDF-Upload)
# Token: sevDesk → Einstellungen → Benutzer → API-Token (32 Zeichen hex, kein Bearer-Prefix)
SEVDESK_API_TOKEN=
# SEVDESK_BASE_URL=https://my.sevdesk.de/api/v1
# SEVDESK_CONTACT_PERSON_ID=471187
# SEVDESK_DEFAULT_PART_ID=31574311

# Preise: netto (B2B), Zahlung inkl. 19 % MwSt. über Stripe Checkout + Rechnung
